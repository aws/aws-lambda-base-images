FROM scratch

ADD 3c9835838118b5dc55ca73b82bc957957b090416c72333d060175c2649b78b1f.tar.xz /
ADD 8fa6e620268ab56d0718e4079052227eb3a5e887f1c429fb75a88ed5c04f6659.tar.xz /
ADD a89e5606f74986d54139aef54250c19e6a18fb6209043ad4b98390f6ceaaa664.tar.xz /
ADD f90aa5de6a53f83d56b88c1fb363d9f5282922e58da04ab3507bd8f55a3660bb.tar.xz /

ENV LANG=en_US.UTF-8
ENV TZ=:/etc/localtime
ENV PATH=/var/lang/bin:/usr/local/bin:/usr/bin/:/bin:/opt/bin
ENV LD_LIBRARY_PATH=/var/lang/lib:/lib64:/usr/lib64:/var/runtime:/var/runtime/lib:/var/task:/var/task/lib:/opt/lib
ENV LAMBDA_TASK_ROOT=/var/task
ENV LAMBDA_RUNTIME_DIR=/var/runtime

WORKDIR /var/task

ENTRYPOINT ["/lambda-entrypoint.sh"]
